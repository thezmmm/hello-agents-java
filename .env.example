# Copy this file to .env and fill in your values.
# .env is in .gitignore and will never be committed.

# API Key — required (works with OpenAI, Anthropic compatibility layer, or any OpenAI-compatible provider)
LLM_API_KEY=sk-...

# API Base URL — optional, defaults to https://api.openai.com/v1
# Override for other providers or local models (e.g. Ollama, DeepSeek, Qwen, etc.)
# LLM_BASE_URL=https://api.openai.com/v1

# Model name — optional, defaults to gpt-4o
# LLM_MODEL=gpt-4o
